@inherits LayoutComponentBase

<MudThemeProvider Theme="@_theme" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="2" Fixed="true" Dense="false" Style="height:68px;">
        <img src="Logo.png" alt="Thyme It logo" style="height:56px; width:auto;" />
    </MudAppBar>

    <MudMainContent>
        <MudContainer MaxWidth="MaxWidth.Small" Class="pt-4 pb-10">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

@code {
    private readonly MudTheme _theme = new()
    {
        PaletteLight = new PaletteLight
        {
            Primary            = "#E65100",
            PrimaryContrastText = "#FFFFFF",
            Secondary          = "#FF8F00",
            SecondaryContrastText = "#FFFFFF",
            AppbarBackground   = "#E65100",
            AppbarText         = "#FFFFFF",
            Background         = "#FFF8F1",
            Surface            = "#FFFFFF",
        }
    };
}
